# Supabase project URL. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (publishable) key. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase service-role key. SECRET. Server-only — never expose to the browser.
# Used by lib/supabase/admin.ts for privileged operations (inserts, updates that
# bypass RLS, admin actions).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
