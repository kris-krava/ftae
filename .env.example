# Supabase project URL. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (publishable) key. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase service-role key. SECRET. Server-only — never expose to the browser.
# Used by lib/supabase/admin.ts for privileged operations (inserts, updates that
# bypass RLS, admin actions).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Sentry — error tracking. Get values from https://sentry.io/settings/<org>/projects/ftae/keys/
# Leave unset locally to disable Sentry in dev (no errors will be reported).
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
SENTRY_DSN=https://...@o....ingest.sentry.io/...
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=ftae
# SENTRY_AUTH_TOKEN is build-time only — set on Vercel + locally only when you
# need to test source-map upload. Get from https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_...

# Upstash Redis (rate limiting). Optional in dev — falls back to in-memory.
# Required in production.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=A...

# Cloudflare R2 (storage backups). Used by .github/workflows/storage-backup.yml.
# Set as GitHub Actions secrets, not in .env.local.
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=ftae-storage-backups
